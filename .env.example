# Client content mode: mock | auto | live
# mock = curated fixtures only (demo-safe, no network)
# auto = try live once, then fall back to mock
# live = surface live errors without silent fallback
VITE_CONTENT_MODE=mock

# Server-only secrets for /api/reflect (never prefix with VITE_)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
